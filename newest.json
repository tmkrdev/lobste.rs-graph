[{"short_id":"d0vsgl","created_at":"2026-06-21T05:41:47.000-05:00","title":"Is AI ruining our skills? Early results are in and they’re not good","url":"https://www.nature.com/articles/d41586-026-01947-1","score":27,"flags":1,"comment_count":3,"description":"","description_plain":"","submitter_user":"jaypatelani","user_is_author":false,"tags":["vibecoding"],"short_id_url":"https://lobste.rs/s/d0vsgl","comments_url":"https://lobste.rs/s/d0vsgl/is_ai_ruining_our_skills_early_results_are"},{"short_id":"5j33bp","created_at":"2026-06-21T03:41:24.000-05:00","title":"Apple Internals: Swift in the Kernel","url":"https://blog.calif.io/p/apple-internals-swift-in-the-kernel","score":13,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"heavyrain266","user_is_author":false,"tags":["osdev","swift"],"short_id_url":"https://lobste.rs/s/5j33bp","comments_url":"https://lobste.rs/s/5j33bp/apple_internals_swift_kernel"},{"short_id":"ozr1zf","created_at":"2026-06-21T03:24:37.000-05:00","title":"Forward to Hell? On Misusing Transparent DNS Forwarders For Amplification Attacks","url":"https://labs.ripe.net/author/mkoch/forward-to-hell-on-misusing-transparent-dns-forwarders-for-amplification-attacks/","score":3,"flags":0,"comment_count":0,"description":"\u003cp\u003eThe interesting bit is that transparent DNS forwarders can bypass some existing resolver protections and scale reflective amplification attacks through anycast resolver infrastructure.\u003c/p\u003e\n","description_plain":"The interesting bit is that transparent DNS forwarders can bypass some existing resolver protections and scale reflective amplification attacks through anycast resolver infrastructure.","submitter_user":"jaguar","user_is_author":false,"tags":["networking","security"],"short_id_url":"https://lobste.rs/s/ozr1zf","comments_url":"https://lobste.rs/s/ozr1zf/forward_hell_on_misusing_transparent_dns"},{"short_id":"wgpa6x","created_at":"2026-06-21T02:19:03.000-05:00","title":"cl-bbs: the schemeBBS-like textboard rewritten in Common Lisp","url":"https://github.com/ryukinix/cl-bbs","score":4,"flags":0,"comment_count":2,"description":"\u003cp\u003eI really like textboards, I think they are some kind superior than imageboard like reddit. I really love authless applications due its simplicity and privacy centric without complication, like strong cryptography and such.\u003c/p\u003e\n\u003cp\u003eI've been hosting a SchemeBBS instance for the last 2 years, but MIT scheme is not my favorite Lisp and I particularly think the ecosystem is pretty limited to the application grows with the features I want. The main different feature from schemeBBS are:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003epersistent preferences, like themes and default board\u003c/li\u003e\n\u003cli\u003epreview of image urls (that's kind crossing textboard concepts, but pretty useful — no image host anyway)\u003c/li\u003e\n\u003cli\u003eadmin page for content moderation\u003c/li\u003e\n\u003cli\u003esearch system\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003eI would like feedback of any kind, thank you for your attention until here.\u003c/p\u003e\n","description_plain":"I really like textboards, I think they are some kind superior than imageboard like reddit. I really love authless applications due its simplicity and privacy centric without complication, like strong cryptography and such.\r\n\r\nI've been hosting a SchemeBBS instance for the last 2 years, but MIT scheme is not my favorite Lisp and I particularly think the ecosystem is pretty limited to the application grows with the features I want. The main different feature from schemeBBS are:\r\n\r\n- persistent preferences, like themes and default board \r\n- preview of image urls (that's kind crossing textboard concepts, but pretty useful — no image host anyway) \r\n- admin page for content moderation \r\n- search system\r\n\r\nI would like feedback of any kind, thank you for your attention until here.","submitter_user":"lerax","user_is_author":false,"tags":["lisp","programming"],"short_id_url":"https://lobste.rs/s/wgpa6x","comments_url":"https://lobste.rs/s/wgpa6x/cl_bbs_schemebbs_like_textboard"},{"short_id":"xtuz4x","created_at":"2026-06-21T01:26:30.000-05:00","title":"Improvements to std::format in C++26","url":"https://mariusbancila.ro/blog/2026/06/19/improvements-to-stdformat-in-c26/","score":5,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"raymii","user_is_author":false,"tags":["c++"],"short_id_url":"https://lobste.rs/s/xtuz4x","comments_url":"https://lobste.rs/s/xtuz4x/improvements_std_format_c_26"},{"short_id":"vutq1m","created_at":"2026-06-21T01:24:43.000-05:00","title":"Windows UI evolution: Clicking an unassociated file","url":"https://movq.de/blog/postings/2026-06-20/0/POSTING-en.html","score":22,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"raymii","user_is_author":false,"tags":["windows"],"short_id_url":"https://lobste.rs/s/vutq1m","comments_url":"https://lobste.rs/s/vutq1m/windows_ui_evolution_clicking"},{"short_id":"z4vrld","created_at":"2026-06-21T00:35:25.000-05:00","title":"Mark-of-the-web and pinning installers to sites","url":"https://blog.randomoracle.io/2026/06/20/mark-of-the-web-and-pinning-installers-to-sites/","score":3,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"raymii","user_is_author":false,"tags":["security","web"],"short_id_url":"https://lobste.rs/s/z4vrld","comments_url":"https://lobste.rs/s/z4vrld/mark_web_pinning_installers_sites"},{"short_id":"lhvnq1","created_at":"2026-06-21T00:31:12.000-05:00","title":"See in CMYK","url":"https://artsandculture.google.com/experiment/8AEAytzXr9rLvQ","score":2,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"ohrv","user_is_author":false,"tags":["art","design"],"short_id_url":"https://lobste.rs/s/lhvnq1","comments_url":"https://lobste.rs/s/lhvnq1/see_cmyk"},{"sho