[{"short_id":"msy3ri","created_at":"2026-04-21T05:58:25.000-05:00","title":"Good architecture shouldn't need a carrot or a stick","url":"https://frederickvanbrabant.com/blog/2026-04-17-good-architecture-shouldnt-need-a-carrot-or-a-stick/","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"TheEdonian","user_is_author":true,"tags":["practices"],"short_id_url":"https://lobste.rs/s/msy3ri","comments_url":"https://lobste.rs/s/msy3ri/good_architecture_shouldn_t_need_carrot"},{"short_id":"5ktlik","created_at":"2026-04-21T05:18:50.000-05:00","title":"Narwhal v0.6.0 – message broker for edge apps, now with channel persistence","url":"https://github.com/lonewolf-io/narwhal/releases/tag/narwhal-0.6.0","score":1,"flags":0,"comment_count":0,"description":"\u003cp\u003ehi again! i'm back with a new release of Narwhal, the lightweight message broker for edge apps i shared a while ago. the headline change in v0.6.0 is channel persistence: channels and their message history can now be durably stored on disk, so subscribers can replay missed messages after reconnecting. also swapped the async runtime from monoio to compio (still io_uring on Linux), and added first-class Prometheus metrics.\u003c/p\u003e\n","description_plain":"hi again! i'm back with a new release of Narwhal, the lightweight message broker for edge apps i shared a while ago. the headline change in v0.6.0 is channel persistence: channels and their message history can now be durably stored on disk, so subscribers can replay missed messages after reconnecting. also swapped the async runtime from monoio to compio (still io_uring on Linux), and added first-class Prometheus metrics.","submitter_user":"ortuman","user_is_author":true,"tags":["programming","release","rust"],"short_id_url":"https://lobste.rs/s/5ktlik","comments_url":"https://lobste.rs/s/5ktlik/narwhal_v0_6_0_message_broker_for_edge_apps"},{"short_id":"p3fzyr","created_at":"2026-04-21T05:17:18.000-05:00","title":"Finishing Things","url":"https://ratfactor.com/finishing-things","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"jbauer","user_is_author":false,"tags":["practices"],"short_id_url":"https://lobste.rs/s/p3fzyr","comments_url":"https://lobste.rs/s/p3fzyr/finishing_things"},{"short_id":"xqmug2","created_at":"2026-04-21T05:09:48.000-05:00","title":"What is your go-to project for learning a new language?","url":"","score":2,"flags":0,"comment_count":1,"description":"\u003cp\u003eIve been playing around with learning a lisp language for a while, and I recently decided to go for it and learn \u003ca href=\"https://fennel-lang.org/\" rel=\"ugc\"\u003efennel\u003c/a\u003e (as I already am comfortable with lua) just to see if I like lisps as a class. Normally, I try to do the first 5-10 days of a previous \u003ca href=\"https://adventofcode.com/\" rel=\"ugc\"\u003eadvent of code\u003c/a\u003e to pick up a lang.\u003c/p\u003e\n\u003cp\u003eSetting up my advent of code environment got me wondering: what projects do other people use to learn new languages/tooling? Id love to hear how other people approach learning a new skill.\u003c/p\u003e\n","description_plain":"Ive been playing around with learning a lisp language for a while, and I recently decided to go for it and learn [fennel](https://fennel-lang.org/) (as I already am comfortable with lua) just to see if I like lisps as a class. Normally, I try to do the first 5-10 days of a previous [advent of code](https://adventofcode.com/) to pick up a lang.\r\n\r\nSetting up my advent of code environment got me wondering: what projects do other people use to learn new languages/tooling? Id love to hear how other people approach learning a new skill.","submitter_user":"Toric","user_is_author":true,"tags":["education","practices"],"short_id_url":"https://lobste.rs/s/xqmug2","comments_url":"https://lobste.rs/s/xqmug2/what_is_your_go_project_for_learning_new"},{"short_id":"wt6xvx","created_at"