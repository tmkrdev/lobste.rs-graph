[{"short_id":"njd25h","created_at":"2026-05-14T15:24:58.000-05:00","title":"Core Team Panel - Gleam Gathering 2026","url":"https://youtu.be/LgfzH_WBlr4","score":4,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"crowdhailer","user_is_author":true,"tags":["gleam","video"],"short_id_url":"https://lobste.rs/s/njd25h","comments_url":"https://lobste.rs/s/njd25h/core_team_panel_gleam_gathering_2026"},{"short_id":"ctny35","created_at":"2026-05-14T15:17:58.000-05:00","title":"The Reverse Centaur's Guide to Life After AI","url":"https://www.kickstarter.com/projects/doctorow/the-reverse-centaurs-guide-to-life-after-ai","score":0,"flags":2,"comment_count":0,"description":"","description_plain":"","submitter_user":"fab23","user_is_author":false,"tags":["book","culture"],"short_id_url":"https://lobste.rs/s/ctny35","comments_url":"https://lobste.rs/s/ctny35/reverse_centaur_s_guide_life_after_ai"},{"short_id":"pegkgv","created_at":"2026-05-14T14:43:13.000-05:00","title":"PostgreSQL 18.4, 17.10 closing 11 CVEs","url":"https://www.postgresql.org/about/news/postgresql-184-1710-1614-1518-and-1423-released-3297/","score":11,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"tsg","user_is_author":false,"tags":["databases"],"short_id_url":"https://lobste.rs/s/pegkgv","comments_url":"https://lobste.rs/s/pegkgv/postgresql_18_4_17_10_closing_11_cves"},{"short_id":"qmlp53","created_at":"2026-05-14T13:52:15.000-05:00","title":"Spam Resistant Forges","url":"https://blog.feld.me/posts/2026/05/spam-resistant-forges/","score":5,"flags":0,"comment_count":2,"description":"","description_plain":"","submitter_user":"fab23","user_is_author":false,"tags":["vcs"],"short_id_url":"https://lobste.rs/s/qmlp53","comments_url":"https://lobste.rs/s/qmlp53/spam_resistant_forges"},{"short_id":"qfbsno","created_at":"2026-05-14T13:41:17.000-05:00","title":"First public macOS kernel memory corruption exploit on Apple M5","url":"https://blog.calif.io/p/first-public-kernel-memory-corruption","score":5,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"fro","user_is_author":false,"tags":["mac","security"],"short_id_url":"https://lobste.rs/s/qfbsno","comments_url":"https://lobste.rs/s/qfbsno/first_public_macos_kernel_memory"},{"short_id":"zp6fnc","created_at":"2026-05-14T12:07:11.000-05:00","title":"SQL’s ORDER BY Has Come a Long Way","url":"https://modern-sql.com/blog/2026-05/order-by-history","score":7,"flags":0,"comment_count":2,"description":"","description_plain":"","submitter_user":"radim","user_is_author":false,"tags":["databases"],"short_id_url":"https://lobste.rs/s/zp6fnc","comments_url":"https://lobste.rs/s/zp6fnc/sql_s_order_by_has_come_long_way"},{"short_id":"mithjg","created_at":"2026-05-14T12:03:08.000-05:00","title":"Linux Compromises, Broken Embargoes, and the Shrinking Patch Window","url":"https://www.askbaize.com/blog/linux-compromises-broken-embargoes-and-the-shrinking-patch-window","score":3,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"binarycleric","user_is_author":false,"tags":["linux"],"short_id_url":"https://lobste.rs/s/mithjg","comments_url":"https://lobste.rs/s/mithjg/linux_compromises_broken_embargoes"},{"short_id":"wee21u","created_at":"2026-05-14T12:00:24.000-05:00","title":"\"This is written by an LLM\" comments should be flagged as off-topic","url":"","score":16,"flags":5,"comment_count":27,"description":"\u003cp\u003eThere've been endless discussions about whether we should ban LLM-generated text, or change the ai/vibecoding tags, or etc.  The general consensus seems to be (???) flag low-effort/uninformative stories as spam and move on.\u003c/p\u003e\n\u003cp\u003eMy proposal here is that \u003cem\u003ecomments\u003c/em\u003e on these stories that just say \"this is LLM slop\" or something equivalent should be flagged as off-topic.  Clearly everyone has different thresholds for what triggers their \"slop-o-meter\" but at least 80% of the reason I read lobsters is for the quality of the commentary here, and it's frustrating to have to wade through arguments about whether the story under discussion is LLM slop or not.  It's also frustrating to \u003cem\u003esubmit\u003c/em\u003e a story that I thought was interesting and (for whatever reasons) didn't trip my slop-o-meter, and then have the only comment be \"would have been a nice article if it weren't written by an LLM\".  It's \u003cem\u003eeven more frustrating\u003c/em\u003e, and frankly kindof demoralizing, to have an article that I wrote (without an LLM) get submitted and then get accused of it being LLM-generated [1].\u003c/p\u003e\n\u003cp\u003eI get that LLMs are polarizing and frustrating to everyone in the community; at this point I don't think anybody is going to change their minds about anything here, so this proposal is \"In addition to 'flag low-effort articles as spam and move on', we should also 'flag this meta commentary as off-topic and move on'\".\u003c/p\u003e\n\u003chr\u003e\n\u003cp\u003e[1] To be clear that hasn't happened here for articles I've written, but I have gotten that reaction on other platforms, and I've witnessed that happen to other authors on Lobsters.\u003c/p\u003e\n","description_plain":"There've been endless discussions about whether we should ban LLM-generated text, or change the ai/vibecoding tags, or etc.  The general consensus seems to be (???) flag low-effort/uninformative stories as spam and move on.\r\n\r\nMy proposal here is that _comments_ on these stories that just say \"this is LLM slop\" or something equivalent should be flagged as off-topic.  Clearly everyone has different thresholds for what triggers their \"slop-o-meter\" but at least 80% of the reason I read lobsters is for the quality of the commentary here, and it's frustrating to have to wade through arguments about whether the story under discussion is LLM slop or not.  It's also frustrating to _submit_ a story that I thought was interesting and (for whatever reasons) didn't trip my slop-o-meter, and then have the only comment be \"would have been a nice article if it weren't written by an LLM\".  It's _even more frustrating_, and frankly kindof demoralizing, to have an article that I wrote (without an LLM) get submitted and then get accused of it being LLM-generated [1].\r\n\r\nI get that LLMs are polarizing and frustrating to everyone in the community; at this point I don't think anybody is going to change their minds about anything here, so this proposal is \"In addition to 'flag low-effort articles as spam and move on', we should also 'flag this meta commentary as off-topic and move on'\".\r\n\r\n---\r\n\r\n[1] To be clear that hasn't happened here for articles I've written, but I have gotten that reaction on other platforms, and I've witnessed that happen to other authors on Lobsters.","submitter_user":"drmorr","user_is_author":true,"tags":["meta"],"short_id_url":"https://lobste.rs/s/wee21u","comments_url":"https://lobste.rs/s/wee21u/this_is_written_by_llm_comments_should_be"},{"short_id":"ci0tgq","created_at":"2026-05-14T11:12:49.000-05:00","title":"How I Moved My Digital Stack to Europe","url":"https://monokai.com/articles/how-i-moved-my-digital-stack-to-europe/","score":13,"flags":2,"comment_count":4,"description":"","description_plain":"","submitter_user":"mpweiher","user_is_author":false,"tags":["privacy"],"short_id_url":"https://lobste.rs/s/ci0tgq","comments_url":"https://lobste.rs/s/ci0tgq/how_i_moved_my_digital_stack_europe"},{"short_id":"x3jzgx","created_at":"2026-05-14T10:52:48.000-05:00","title":"HDD Firmware Hacking Part 1","url":"https://icode4.coffee/?p=1465","score":7,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"lander","user_is_author":false,"tags":["assembly","reversing"],"short_id_url":"https://lobste.rs/s/x3jzgx","comments_url":"https://lobste.rs/s/x3jzgx/hdd_firmware_hacking_part_1"},{"short_id":"tt58t8"