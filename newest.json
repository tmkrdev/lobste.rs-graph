olks here.","submitter_user":"mitsuhiko","user_is_author":true,"tags":["vibecoding"],"short_id_url":"https://lobste.rs/s/yrmpxy","comments_url":"https://lobste.rs/s/yrmpxy/better_models_worse_tools"},{"short_id":"svm2dp","created_at":"2026-07-04T16:37:21.000-05:00","title":"Returning to Zig","url":"https://gracefulliberty.com/articles/return-to-zig/","score":51,"flags":0,"comment_count":2,"description":"","description_plain":"","submitter_user":"liberty","user_is_author":true,"tags":["zig"],"short_id_url":"https://lobste.rs/s/svm2dp","comments_url":"https://lobste.rs/s/svm2dp/returning_zig"},{"short_id":"f2xgzo","created_at":"2026-07-04T16:28:33.000-05:00","title":"Non-hybrid PQ-only TLS and the MIKEY-IBAKE intervention","url":"https://libroot.org/posts/non-hybrid-pq-only-tls-and-mikey-ibake/","score":2,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"ecksdee","user_is_author":false,"tags":["cryptography","security"],"short_id_url":"https://lobste.rs/s/f2xgzo","comments_url":"https://lobste.rs/s/f2xgzo/non_hybrid_pq_only_tls_mikey_ibake"},{"short_id":"5akjfx","created_at":"2026-07-04T15:41:03.000-05:00","title":"The Lion, The Witch, and the audacity of recruiters","url":"https://hauleth.dev/post/the-lion-the-witch-and-the-aduacity-of-recruiter/","score":26,"flags":2,"comment_count":9,"description":"","description_plain":"","submitter_user":"hauleth","user_is_author":true,"tags":["job","rant"],"short_id_url":"https://lobste.rs/s/5akjfx","comments_url":"https://lobste.rs/s/5akjfx/lion_witch_audacity_recruiters"},{"short_id":"utznd2","created_at":"2026-07-04T13:50:46.000-05:00","title":"We Need A Way To Prove Personhood Online","url":"https://www.noemamag.com/we-need-a-way-to-prove-personhood-online","score":2,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"quad","user_is_author":false,"tags":["culture"],"short_id_url":"https://lobste.rs/s/utznd2","comments_url":"https://lobste.rs/s/utznd2/we_ne