[{"short_id":"mml1nk","created_at":"2026-04-06T12:28:56.000-05:00","title":"The Precision ST-22 Signal Tracer","url":"https://wereboar.com/projects/index.php/2026/04/06/the-precision-st-22-signal-tracer-part-1-observations/","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"jeffhuang","user_is_author":false,"tags":["hardware"],"short_id_url":"https://lobste.rs/s/mml1nk","comments_url":"https://lobste.rs/s/mml1nk/precision_st_22_signal_tracer"},{"short_id":"q49re5","created_at":"2026-04-06T11:38:37.000-05:00","title":"Returning to work after a year-long illness - what AI tools \u0026 workflows are you using nowadays?","url":"","score":2,"flags":0,"comment_count":0,"description":"\u003cp\u003eI'm getting ready to return to work after a pretty intense year. Last May I was diagnosed with Guillain-Barré Syndrome, an autoimmune condition where the body attacks the nervous system. I spent two months in a wheelchair and about 10 months in rehab/day hospitalization working to get my body back to where it was.\u003c/p\u003e\n\u003cp\u003eThings are much better now (I'm even back to running), though my hands are still quite weak, but improving slowly.\u003c/p\u003e\n\u003cp\u003eDuring this year I wasn’t working, focusing mostly on recovery while the industry kept evolving.\u003c/p\u003e\n\u003cp\u003eI did my best to stay up to date but I'd love to hear what tools you're using these days (Claude Code, Cursor, etc.) and what workflows are working best for you.\u003c/p\u003e\n\u003cp\u003eBefore I got sick, Cursor was my main tool, but there was still a lot of hands-on coding. Now it seems like people barely write code except for specific cases or interesting problems.\u003c/p\u003e\n\u003cp\u003eWould really appreciate as much detail as possible.\nAlso happy to answer any questions about what I went through this past year.\u003c/p\u003e\n","description_plain":"I'm getting ready to return to work after a pretty intense year. Last May I was diagnosed with Guillain-Barré Syndrome, an autoimmune condition where the body attacks the nervous system. I spent two months in a wheelchair and about 10 months in rehab/day hospitalization working to get my body back to where it was.\r\n\r\nThings are much better now (I'm even back to running), though my hands are still quite weak, but improving slowly.\r\n\r\nDuring this year I wasn’t working, focusing mostly on recovery while the industry kept evolving.\r\n\r\nI did my best to stay up to date but I'd love to hear what tools you're using these days (Claude Code, Cursor, etc.) and what workflows are working best for you.\r\n\r\nBefore I got sick, Cursor was my main tool, but there was still a lot of hands-on coding. Now it seems like people barely write code except for specific cases or interesting problems.\r\n\r\nWould really appreciate as much detail as possible.\r\nAlso happy to answer any questions about what I went through this past year.","submitter_user":"Dew","user_is_author":true,"tags":["ai","ask"],"short_id_url":"https://lobste.rs/s/q49re5","comments_url":"https://lobste.rs/s/q49re5/returning_work_after_year_long_illness"},{"short_id":"aqaobg","created_at":"2026-04-06T11:23:07.000-05:00","title":"Someone good at CSS help, my website design is dying","url":"https://ahti.space/~nortti/writeups/my-website-design-is-dying.html","score":4,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"nortti","user_is_author":true,"tags":["css"],"short_id_url":"https://lobste.rs/s/aqaobg","comments_url":"https://lobste.rs/s/aqaobg/someone_good_at_css_help_my_website_design"},{"short_id":"pfoohx","created_at":"2026-04-06T11:20:54.000-05:00","title":"A Cryptography Engineer’s Perspective on Quantum Computing Timelines","url":"https://words.filippo.io/crqc-timeline/","score":7,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"fkooman","user_is_author":false,"tags":["cryptography","security"],"sh