lmost 0 agent lines left.","submitter_user":"dzervas","user_is_author":true,"tags":["vibecoding"],"short_id_url":"https://lobste.rs/s/s4ha0g","comments_url":"https://lobste.rs/s/s4ha0g/mcp_firewall_better_policy_engine_for_cli"}]