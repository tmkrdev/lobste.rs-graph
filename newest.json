[{"short_id":"vtlqfy","created_at":"2026-06-05T17:50:44.000-05:00","title":"The Anatomy of a Learning Stall","url":"https://tagide.com/blog/llm/the-anatomy-of-a-learning-stall/","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"Foxboron","user_is_author":false,"tags":["education","vibecoding"],"short_id_url":"https://lobste.rs/s/vtlqfy","comments_url":"https://lobste.rs/s/vtlqfy/anatomy_learning_stall"},{"short_id":"ntiqqs","created_at":"2026-06-05T16:52:05.000-05:00","title":"Let's stop using flags as down-vote","url":"","score":4,"flags":0,"comment_count":0,"description":"\u003cp\u003eFrom: \u003ca href=\"https://lobste.rs/about\" rel=\"ugc\"\u003ehttps://lobste.rs/about\u003c/a\u003e\u003c/p\u003e\n\u003cblockquote\u003e\n\u003cp\u003ePlease don't use flagging to try to push down topics or people you don't like; click \"hide\" on the story and move on rather than clutter up the mod dashboard with false alarms.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eThings have been pretty hot here recently, especially with ongoing discussions about AI and site policy. The flagging seems to be getting out of hand for good faith comments of both pro- and anti-AI sentiment, and generally the whole vibe is getting increasingly hot, even over the few months I have been here. Since we cannot agree, we can at least quell this abuse of the site's features and either have good faith discussions that start with \"I disagree\" or better utilisation of hide and [-].\u003c/p\u003e\n","description_plain":"From: https://lobste.rs/about\r\n\r\n\u003e Please don't use flagging to try to push down topics or people you don't like; click \"hide\" on the story and move on rather than clutter up the mod dashboard with false alarms.\r\n\r\nThings have been pretty hot here recently, especially with ongoing discussions about AI and site policy. The flagging seems to be getting out of hand for good faith comments of both pro- and anti-AI sentiment, and generally the whole vibe is getting increasingly hot, even over the few months I have been here. Since we cannot agree, we can at least quell this abuse of the site's features and either have good faith discussions that start with \"I disagree\" or better utilisation of hide and [-].","submitter_user":"addison","user_is_author":true,"tags":["culture","meta"],"short_id_url":"https://lobste.rs/s/ntiqqs","comments_url":"https://lobste.rs/s/ntiqqs/let_s_stop_using_flags_as_down_vote"},{"short_id":"k9wvkn","created_at":"2026-06-05T15:28:19.000-05:00","title":"pg_durable: PostgreSQL in-database durable execution","url":"https://github.com/microsoft/pg_durable","score":4,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"mmastrac","user_is_author":false,"tags":["databases"],"short_id_url":"https://lobste.rs/s/k9wvkn","comments_url":"https://lobste.rs/s/k9wvkn/pg_durable_postgresql_database_durable"},{"short_id":"oqlpna","created_at":"2026-06-05T13:40:29.000-05:00","title":"Stop Using Conventional Commits","url":"https://sumnerevans.com/posts/software-engineering/stop-using-conventional-commits/","score":38,"flags":0,"comment_count":5,"description":"","description_plain":"","submitter_user":"dryya","user_is_author":false,"tags":["practices"],"short_id_url":"https://lobste.rs/s/oqlpna","comments_url":"https://lobste.rs/s/oqlpna/stop_using_conventional_commits"},{"short_id":"mf5ryi","created_at":"2026-06-05T13:14:42.000-05:00","title":"Did Claude Increase Bugs in rsync?","url":"https://alexispurslane.github.io/rsync-analysis/","score":35,"flags":2,"comment_count":24,"description":"","description_plain":"","submitter_user":"wonk","user_is_author":false,"tags":["security","vibecoding"],"short_id_url":"https://lobste.rs/s/mf5ryi","comments_url":"https://lobste.rs/s/mf5ryi/did_claude_increase_bugs_rsync"},{"short_id":"ehxqv9","created_at":"2026-06-05T12:36:05.000-05:00","title":"Using Fedora Silverblue for Compositor Development","url":"h