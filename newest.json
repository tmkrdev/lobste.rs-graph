[{"short_id":"bqer6o","created_at":"2026-05-27T07:08:39.000-05:00","title":"Sidekick: keep using neovim while a dozen agents rewrite your code","url":"https://github.com/NishantJoshi00/sidekick","score":1,"flags":0,"comment_count":0,"description":"\u003cp\u003eA dozen agents are editing my codebase right now. I'm one of them.\u003c/p\u003e\n\u003cp\u003eI open neovim a dozen times a day. Quick edit, close. Quick edit, close. Claude Code does the heavy lifting and I dip in for the moments that need my hands on the keys.\u003c/p\u003e\n\u003cp\u003eIt only works because neovim is muscle memory. I can almost close my eyes in there.\u003c/p\u003e\n\u003cp\u003eBut any one of those agents can rewrite the file under my cursor while I'm in it. The reflexes don't help if the ground keeps moving.\u003c/p\u003e\n\u003cp\u003eSo I built Sidekick. Not folke's. Not a plugin. It sits outside neovim and keeps the ground still while the agents work.\u003c/p\u003e\n","description_plain":"A dozen agents are editing my codebase right now. I'm one of them.\r\n\r\nI open neovim a dozen times a day. Quick edit, close. Quick edit, close. Claude Code does the heavy lifting and I dip in for the moments that need my hands on the keys.\r\n\r\nIt only works because neovim is muscle memory. I can almost close my eyes in there.\r\n\r\nBut any one of those agents can rewrite the file under my cursor while I'm in it. The reflexes don't help if the ground keeps moving.\r\n\r\nSo I built Sidekick. Not folke's. Not a plugin. It sits outside neovim and keeps the ground still while the agents work.","submitter_user":"nishantjosh","user_is_author":true,"tags":["ai","vibecoding","vim"],"short_id_url":"https://lobste.rs/s/bqer6o","comments_url":"https://lobste.rs/s/bqer6o/sidekick_keep_using_neovim_while_dozen"},{"short_id":"zfm1lc","created_at":"2026-05-27T06:57:38.000-05:00","title":"space-tree: Workspace Management Trees in Emacs","url":"https://www.chiply.dev/post-emacs-space-tree","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"chiply","user_is_author":true,"tags":["emacs"],"short_id_url":"https://lobste.rs/s/zfm1lc","comments_url":"https://lobste.rs/s/zfm1lc/space_tree_workspace_management_trees"},{"short_id":"ktwvtk","created_at":"2026-05-27T05:04:18.000-05:00","title":"5 PostgreSQL locking behaviors that trip people up","url":"https://dev.to/shinyakato_/5-postgresql-locking-behaviors-that-trip-people-up-4k7n","score":2,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"sjamaan","user_is_author":false,"tags":["databases"],"short_id_url":"https://lobste.rs/s/ktwvtk","comments_url":"https://lobste.rs/s/ktwvtk/5_postgresql_locking_behaviors_trip"},{"short_id":"cvyshr","created_at":"2026-05-27T05:02:10.000-05:00","title":"Converting shallow Git bundles into normal repositories","url":"https://runxiyu.org/comp/shallowbundle/","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"runxiyu","user_is_author":true,"tags":["vcs"],"short_id_url":"https://lobste.rs/s/cvyshr","comments_url":"https://lobste.rs/s/cvyshr/converting_shallow_git_bundles_into"},{"short_id":"rzdtx8","created_at":"2026-05-27T05:01:18.000-05:00","title":"May I recommend thinking of Emacs as your Fortress of Solitude","url":"https://martinsos.com/posts/may-recommend-emacs-home-base","score":11,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"confusedalex","user_is_author":false,"tags":["emacs"],"short_id_url":"https://lobste.rs/s/rzdtx8","comments_url":"https://lobste.rs/s/rzdtx8/may_i_recommend_thinking_emacs_as_your"},{"short_id":"tgsqoy","created_at":"2026-05-27T04:35:53.000-05:00","title":"The Untold Story About W Social: Unconventional Beginnings, Strategic Pitches and Conflicting Signals","url":"https://blog.elenarossini.com/the-untold-story-about-w-social-unconventional-beginnings-strategic-pitches-conflicting-signals/","score":0,"flags":2,"comment_count":0,"description":"","description_plain":"","submitter_user":"SoapDog","user_is_author":false,"tags":["culture","rant"],"short_id_url":"https://lobste.rs/s/tgsqoy","comments_url":"https://lobste.rs/s/tgsqoy/untold_story_about_w_social"},{"short_id":"ynrwwo","created_at":"2026-05-27T03:13:35.000-05:00","title":"Keyboard latency probe","url":"https://xkqr.org/bellwether/keyboardtest.html","score":5,"flags":0,"comment_count":4,"description":"\u003cp\u003eHello, fellow geeks!\u003c/p\u003e\n\u003cp\u003eI was working on a side project when I discovered something odd about how keyboards behave. I only have three keyboards myself to test with, so I would like to recruit your help in providing me data from your keyboards.\u003c/p\u003e\n\u003cp\u003eThe link leads to a simple 3.5 minute browser-based test which lets you record response times and tap durations from your keyboard, and then send them to me. If you can take the time out of your day to help me better understand this, I'd greatly appreciate your contribution.\u003c/p\u003e\n\u003cp\u003eOnce I have enough data, I will naturally share the results of the analysis back with the community. I'd like to also share the raw data, but I haven't yet thought through any potential privacy concerns around this, so I don't yet know if I will.\u003c/p\u003e\n","description_plain":"Hello, fellow geeks!\r\n\r\nI was working on a side project when I discovered something odd about how keyboards behave. I only have three keyboards myself to test with, so I would like to recruit your help in providing me data from your keyboards.\r\n\r\nThe link leads to a simple 3.5 minute browser-based test which lets you record response times and tap durations from your keyboard, and then send them to me. If you can take the time out of your day to help me better understand this, I'd greatly appreciate your contribution.\r\n\r\nOnce I have enough data, I will naturally share the results of the analysis back with the community. I'd like to also share the raw data, but I haven't yet thought through any potential privacy concerns around this, so I don't yet know if I will.","submitter_user":"kqr","user_is_author":true,"tags":["ask","hardware"],"short_id_url":"https://lobste.rs/s/ynrwwo","comments_url":"https://lobste.rs/s/ynrwwo/keyboard_latency_probe"},{"short_id":"cmsgwo","created_at":"2026-05-27T02:32:12.000-05:00","title":"CVE-2026-48710 Starlette Host-Header Auth Bypass","url":"https://badhost.org","score":5,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"hoistbypetard","user_is_author":false,"tags":["python","web"],"short_id_url":"https://lobste.rs/s/cmsgwo","comments_url":"https://lobste.rs/s/cmsgwo/cve_2026_48710_starlette_host_header_auth"},{"short_id":"ffs7xz","created_at":"2026-05-27T00:53:58.000-05:00","title":"Rethinking the GNOME clipboard issues","url":"https://edu4rdshl.dev/posts/rethinking-the-gnome-clipboard-issues/","score":8,"flags":1,"comment_count":4,"description":"","description_plain":"","submitter_user":"edu4rdshl","user_is_author":true,"tags":["vibecoding"],"short_id_url":"https://lobste.rs/s/ffs7xz","comments_url":"https://lobste.rs/s/ffs7xz/rethinking_gnome_clipboard_issues"},{"short_id":"2jdvxa","created_at":"2026-05-27T00:40:47.000-05:00","title":"What are some of your favourite developer tools?","url":"","score":23,"flags":0,"comment_count":38,"description":"\u003cp\u003eDevelopers are so opinionated that it's difficult to pin down one favourite tool !\u003c/p\u003e\n","description_plain":"Developers are so opinionated that it's difficult to pin down one favourite tool !","submitter_user":"dhruvp","user_is_author":true,"tags":["ask","programming"],"short_id_url":"https://lobste.rs/s/2jdvxa","comments_url":"https://lobste.rs/s/2jdvxa/what_are_some_your_favourite_developer"},{"short_id":"sgqbvg","created_at":"2026-05-26T22:21:37.000-05:00","title":"Build System Reworked","url":"https://ziglang.org/devlog/2026/#2026-05-26","