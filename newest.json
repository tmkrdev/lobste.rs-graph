[{"short_id":"hq8i1h","created_at":"2026-07-07T07:49:03.000-05:00","title":"The Popup That Says the Quiet Part Out Loud","url":"https://blog.ppb1701.com/the-popup-that-says-the-quiet-part-out-loud","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"FedericoSchonborn","user_is_author":false,"tags":["ios","vibecoding"],"short_id_url":"https://lobste.rs/s/hq8i1h","comments_url":"https://lobste.rs/s/hq8i1h/popup_says_quiet_part_out_loud"},{"short_id":"xiamhy","created_at":"2026-07-07T07:29:11.000-05:00","title":"Put NetHack on my community app and this 38-year-old game keeps outsmarting me","url":"","score":3,"flags":0,"comment_count":0,"description":"\u003cp\u003eI added NetHack to my community app a while back, unmodified upstream binary running on a shared box. I thought I was adding \"an old roguelike\". I was not prepared. :D\u003c/p\u003e\n\u003cp\u003eIt shipped multiplayer in the 80s and nobody calls it that. Bones files. Someone dies on lvl 12, their ghost and their cursed loot get written to disk, and another player on the same machine walks into that grave later. People are haunting each other with zero configuration.\u003c/p\u003e\n\u003cp\u003e\"The DevTeam thinks of everything\" is not a meme. Every \"surely this won't work\" works. Every \"surely the game doesn't track that\" is tracked. You can wield a cockatrice corpse as a weapon (wear gloves). You can scare monsters by writing Elbereth in the dust. You can dip, rub, sit on, and kick basically anything, and the game has an opinion about all of it. I keep watching people find interactions I didn't know existed, in a game running unmodified on my box.\u003c/p\u003e\n\u003cp\u003eAnd it's still alive. First released in 1987, still maintained by the DevTeam today, and it hangs in MoMA's collection as one of the culturally significant video games. A museum piece that still gets patches. Meanwhile it runs on a potato over a text terminal.\u003c/p\u003e\n\u003cp\u003eLove it :D\u003c/p\u003e\n","description_plain":"I added NetHack to my community app a while back, unmodified upstream binary running on a shared box. I thought I was adding \"an old roguelike\". I was not prepared. :D\r\n\r\nIt shipped multiplayer in the 80s and nobody calls it that. Bones files. Someone dies on lvl 12, their ghost and their cursed loot get written to disk, and another player on the same machine walks into that grave later. People are haunting each other with zero configuration.\r\n\r\n\"The DevTeam thinks of everything\" is not a meme. Every \"surely this won't work\" works. Every \"surely the game doesn't track that\" is tracked. You can wield a cockatrice corpse as a weapon (wear gloves). You can scare monsters by writing Elbereth in the dust. You can dip, rub, sit on, and kick basically anything, and the game has an opinion about all of it. I keep watching people find interactions I didn't know existed, in a game running unmodified on my box.\r\n\r\nAnd it's still alive. First released in 1987, still maintained by the DevTeam today, and it hangs in MoMA's collection as one of the culturally significant video games. A museum piece that still gets patches. Meanwhile it runs on a potato over a text terminal.\r\n\r\nLove it :D","submitter_user":"Bl4ckBe4r","user_is_author":true,"tags":["games"],"short_id_url":"https://lobste.rs/s/xiamhy","comments_url":"https://lobste.rs/s/xiamhy/put_nethack_on_my_community_app_this_38"},{"short_id":"hxjscx","created_at":"2026-07-07T07:09:47.000-05:00","title":"How I'm using CSS View Transitions on this blog","url":"https://blog.omgmog.net/post/how-im-using-css-view-transitions-on-this-blog/","score":2,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"FedericoSchonborn","user_is_author":false,"tags":["css"],"short_id_url":"https://lobste.rs/s/hxjscx","comments_url":"https://lobste.rs/s/hxjscx/how_i_m_using_css_view_transitions_on_this"},{"short_id":"2lhx8n","created_at":"2026-07-07T06:19:11.000-05:00","title":"Finding a needle in a 4 GB haystack: from 0.75 GB/s to 49 GB/s in Go","url":"https://segflow.github.io/post/fast-file-search-go/","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"tcard","user_is_author":false,"tags":["go","performance"],"short_id_url":"https://lobste.rs/s/2lhx8n","comments_url":"https://lobste.rs/s/2lhx8n/finding_needle_4_gb_haystack_from_0_75_gb_s"},{"short_id":"asnoqy","created_at":"2026-07-07T06:00:34.000-05:00","title":"Signed Integers By Default","url":"https://www.gingerbill.org/article/2026/05/03/signed-by-default/","score":5,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"runxiyu","user_is_author":false,"tags":["plt"],"short_id_url":"https://lobste.rs/s/asnoqy","comments_url":"https://lobste.rs/s/asnoqy/signed_integers_by_default"},{"short_id":"txjns0","created_at":"2026-07-07T04:56:21.000-05:00","title":"Reporting a 19+ Years Hidden Linux Kernel Zero-Day for Google kernelCTF: CVE-2026-43456","url":"https://gmo-cybersecurity.com/blog/19-years-hidden-80000-rewarded-reporting-a-linux-kernel-zero-day-for-google-kernelctf/","score":4,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"rrampage","user_is_author":false,"tags":["linux","networking","security"],"short_id_url":"https://lobste.rs/s/txjns0","comments_url":"https://lobste.rs/s/txjns0/reporting_19_years_hidden_linux_kernel"},{"short_id":"hfiihu","created_at":"2026-07-07T04:46:01.000-05:00","title":"Waterfall CAD Playground - A Haskell powered programmable-CAD environment, in the browser with WASM","url":"https://doscienceto.it/waterpark","score":7,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"hungry_joe","user_is_author":true,"tags":["graphics","haskell"],"short_id_url":"https://lobste.rs/s/hfiihu","comments_url":"https://lobste.rs/s/hfiihu/waterfall_cad_playground_haskell"},{"short_id":"709awc","