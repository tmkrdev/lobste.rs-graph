[{"short_id":"ma6jft","created_at":"2026-07-21T10:26:36.521-05:00","title":"FPTalks 2026 — Thu Aug 6, free, online","url":"https://fptalks.org/talks/fptalks26.html","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"JordiGH","user_is_author":false,"tags":["event","math"],"short_id_url":"https://lobste.rs/s/ma6jft","comments_url":"https://lobste.rs/s/ma6jft/fptalks_2026_thu_aug_6_free_online"},{"short_id":"z1alry","created_at":"2026-07-21T10:14:38.099-05:00","title":"lazy-tmux: restore tmux sessions lazily, with scrollback","url":"https://lazy-tmux.xyz","score":2,"flags":0,"comment_count":0,"description":"\u003cp\u003eA tmux session manager in Go. It lists all saved sessions as a tree, but only restores one — its processes and scrollback — when you actually open it, instead of bringing everything back eagerly like resurrect/continuum.\u003c/p\u003e\n\u003cp\u003eThe part I'd most like feedback on is the restore model: what gets re-run is controlled by an allow/denylist matched as regexes over the full command, so servers relaunch but destructive commands don't.\u003c/p\u003e\n\u003cp\u003eWorks with tmux 2.9–3.7b, one-line install.\u003c/p\u003e\n","description_plain":"A tmux session manager in Go. It lists all saved sessions as a tree, but only restores one — its processes and scrollback — when you actually open it, instead of bringing everything back eagerly like resurrect/continuum.\r\n\r\nThe part I'd most like feedback on is the restore model: what gets re-run is controlled by an allow/denylist matched as regexes over the full command, so servers relaunch but destructive commands don't.\r\n\r\nWorks with tmux 2.9–3.7b, one-line install.","submitter_user":"alchemmist","user_is_author":true,"tags":["go","release","show","unix"],"short_id_url":"https://lobste.rs/s/z1alry","comments_url":"https://lobste.rs/s/z1alry/lazy_tmux_restore_tmux_sessions_lazily"},{"short_id":"w031bw","created_at":"2026-07-21T10:13:09.729-05:00","