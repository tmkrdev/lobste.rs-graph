_author":false,"tags":["dotnet"],"short_id_url":"https://lobste.rs/s/imwkxe","comments_url":"https://lobste.rs/s/imwkxe/unions_merged_into_dotnet_11_preview_3"},{"short_id":"2fzuf8","created_at":"2026-03-10T16:33:25.000-05:00","title":"TLA+ as a Design Accelerator: Lessons from the Industry","url":"http://muratbuffalo.blogspot.com/2026/03/tla-as-design-accelerator-lessons-from.html","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"eatonphil","user_is_author":false,"tags":["databases","formalmethods"],"short_id_url":"https://lobste.rs/s/2fzuf8","comments_url":"https://lobste.rs/s/2fzuf8/tla_as_design_accelerator_lessons_from"},{"short_id":"wvewpi","created_at":"2026-03-10T16:12:44.000-05:00","title":"Debian decides not to decide on AI-generated contributions","url":"https://lwn.net/SubscriberLink/1061544/125f911834966dd0/","score":5,"flags":1,"comment_count":0,"description":"","description_plain":"","submitter_user":"telemachus","user_is_author":false,"tags":["vibecoding"],"short_id_url":"https://lobste.rs/s/wvewpi","comments_url":"https://lobste.rs/s/wvewpi/debian_decides_not_decide_on_ai_generated"},{"short_id":"zinlhb","created_at":"2026-03-10T16:11:27.000-05:00","title":"A new LLM-friendly library for Model-Based Testing","url":"https://quint-lang.org/posts/quint_connect","score":1,"flags":1,"comment_count":0,"description":"","description_plain":"","submitter_user":"amw-zero","user_is_author":false,"tags":["formalmethods","testing","vibecoding"],"short_id_url":"https://lobste.rs/s/zinlhb","comments_url":"https://lobste.rs/s/zinlhb/new_llm_friendly_library_for_model_based"},{"short_id":"ne1fzz","created_at":"2026-03-10T16:09:08.000-05:00","title":"Examples for the tcpdump and dig man pages","url":"https://jvns.ca/blog/2026/03/10/examples-for-the-tcpdump-and-dig-man-pages/","score":2,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"dzwdz","user_is_author":false,"tags":["unix"],"shor