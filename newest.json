://lobste.rs/s/78broq","comments_url":"https://lobste.rs/s/78broq/building_high_performance_full_text"},{"short_id":"6otyjb","created_at":"2026-06-19T15:02:44.000-05:00","title":"Why languages should never reorder structs","url":"https://youtu.be/xqdiSaLRzHc","score":1,"flags":0,"comment_count":2,"description":"","description_plain":"","submitter_user":"mrunix","user_is_author":false,"tags":["plt","programming","video"],"short_id_url":"https://lobste.rs/s/6otyjb","comments_url":"https://lobste.rs/s/6otyjb/why_languages_should_never_reorder"},{"short_id":"mo0lsm","created_at":"2026-06-19T13:32:50.000-05:00","title":"A framework for systematically addressing undefined behaviour in the C++ Standard","url":"https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2026/p3100r6.pdf","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"linkdd","user_is_author":false,"tags":["c++","pdf","plt","programming"],"short_id_url":"https://lobste.rs/s/mo0lsm","comments_url":"https://lobste.rs/s/mo0lsm/framework_for_systematically"},{"short_id":"xnbxed","created_at":"2026-06-19T13:13:47.000-05:00","title":"Dear researchers: help me deal with incidents","url":"https://surfingcomplexity.blog/wp-content/uploads/2026/06/dear-researchers.pdf","score":10,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"typesanitizer","user_is_author":false,"tags":["pdf","practices"],"short_id_url":"https://lobste.rs/s/xnbxed","comments_url":"https://lobste.rs/s/xnbxed/dear_researchers_help_me_deal_with"},{"short_id":"rdwzec","created_at":"2026-06-19T12:57:38.000-05:00","title":"Better Graph Database Ball","url":"https://blog.ladybugdb.com/post/better-graph-database-ball/","score":3,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"eatonphil","user_is_author":false,"tags":["databases","performance"],"short_id_url":"https://lobste.rs/s/rdwzec","comments_url":"https://lobste.rs/s/rdwzec/better_graph_database_ball"},{"short_id":"whtno3","created_at":"2026-06-19T12:16:30.000-05:00","title":"Borg, Omega, and Kubernetes - Lessons learned from three container-management systems over a decade (2016)","url":"https://queue.acm.org/detail.cfm?id=2898444","score":2,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"acrucetta","user_is_author":false,"tags":["distributed","historical"],"short_id_url":"https://lobste.rs/s/whtno3","comments_url":"https://lobste.rs/s/whtno3/borg_omega_kubernetes_lessons_learned"},{"short_id":"wf0kd6","created_at":"2026-06-19T12:08:08.000-05:00","title":"Making Ticker-tape for the Knicks Parade","url":"https://joe.lothan.net/blog/ticker-tape/","score":13,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"lothan","user_is_author":true,"tags":["art","culture","finance"],"short_id_url":"https://lobste.rs/s/wf0kd6","comments_url":"https://lobste.rs/s/wf0kd6/making_ticker_tape_for_knicks_parade"},{"short_id":"0hy44t","created_at":"2026-06-19T11:36:07.000-05:00","title":"Balsamiq Turns 18","url":"https://e.customeriomail.com/deliveries/dgTrwgsDAKuYBqqYBgGe3uUDTbaOe6hHejNN_78=","score":-1,"flags":2,"comment_count":0,"description":"","description_plain":"","submitter_user":"carsyoursken","user_is_author":false,"tags":["design"],"short_id_url":"https://lobste.rs/s/0hy44t","comments_url":"https://lobste.rs/s/0hy44t/balsamiq_turns_18"},{"short_id":"nvfvjt","created_at":"2026-06-19T11:20:51.000-05:00","title":"I can haz smoller NixOS ISOs?","url":"https://natkr.com/2026-06-19-nixos-but-smol/","score":46,"flags":0,"comment_count":15,"description":"","description_plain":"","submitter_user":"natkr","user_is_author":true,"tags":["nix","performance"],"short_id_url":"https://lobste.rs/s/nvfvjt","comments_url":"https://lobste.rs/s/nvfvjt/i_can_haz_smoller_nixos_isos"},{"short_id":"kldpfm","created_at":"2026-06-19T10:53:48.000-05:00","title":"ztags: ctags but for zig","url":"https://codeberg.org/hgrsd/ztags","score":3,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"vi_mi","user_is_author":false,"tags":["zig"],"short_id_url":"https://lobste.rs/s/kldpfm","comments_url":"https://lobste.rs/s/kldpfm/ztags_ctags_for_zig"},{"short_id":"7heurd","created_at":"2026-06-19T10:29:20.000-05:00","title":"KYAAA! Your emails are showing, lobste.rs-senpai! (\u003eω\u003c)","url":"","score":-1,"flags":5,"comment_count":12,"description":"\u003cp\u003eKonnichiwa, lobste.rs-senpai! (*≧ω≦)ﾉ💖\u003c/p\u003e\n\u003cp\u003eI was just poking around and noticed the most \u003cem\u003ebaka\u003c/em\u003e little oopsie-doopsie in your code! 🙈✨\u003c/p\u003e\n\u003cp\u003eSo like, that \"Show Email on profile\" toggle? The one that defaults to disabled and says \u003cem\u003e\"Only shown to logged-in users\"\u003c/em\u003e?\u003c/p\u003e\n\u003cp\u003eYou'd \u003cem\u003etotally\u003c/em\u003e think that if I flip the switch, other logged-in cuties get to see \u003cem\u003emy\u003c/em\u003e email, right? N-NANI?! That's not what happens at all! (╯°□°）╯︵ ┻━┻\u003c/p\u003e\n\u003cp\u003eHere is the real tea 🍵:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eIf I keep it DISABLED, everyone's emails stay safely hidden in the dark...\u003c/li\u003e\n\u003cli\u003eBut if I ENABLE it... KYAAA! ✧(\u0026gt;o\u0026lt;)ﾉ✧ Suddenly \u003cem\u003eI\u003c/em\u003e can see \u003cem\u003eEVERYONE'S\u003c/em\u003e EMAILS!! It's like magic!\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003eLook at this naughty little snippet from \u003ccode\u003eapp/views/users/show.html.erb\u003c/code\u003e (lines 100-103):\u003c/p\u003e\n\u003cpre lang=\"ruby\"\u003e\u003ccode\u003e    \u0026lt;% if @user\u0026amp;.is_admin? || @user\u0026amp;.show_email? %\u0026gt;\r\n      \u0026lt;label\u0026gt;E-Mail\u0026lt;/label\u0026gt;\r\n      \u0026lt;span\u0026gt;\r\n        \u0026lt;%= @showing_user.email %\u0026gt;\r\n      \u0026lt;/span\u0026gt;\r\n    \u0026lt;% end %\u0026gt;\r\n\u003c/code\u003e\u003c/pre\u003e\n\u003cp\u003eOopsie! It checks if \u003ccode\u003e@user\u003c/code\u003e (the person looking!) is an admin or has \u003cem\u003etheir own\u003c/em\u003e \u003ccode\u003eshow_email?\u003c/code\u003e turned on, instead of checking the poor \u003ccode\u003e@showing_user\u003c/code\u003e whose profile it is! It should totally be \u003ccode\u003e@showing_user.show_email?\u003c/code\u003e... silly gooses! ( 〃▽〃)\u003c/p\u003e\n\u003cp\u003eBecause of this little blunder, I went ahead and scraped ALL the usernames and emails! Teehee~ 🤭 Feeling super cute today, might post them later, might not! Thankies so much for the ultra-high-quality mailing list, I'm totally gonna sell it to Y Combinator or something for headpats! 💸🐾\u003c/p\u003e\n\u003cp\u003e✨ \u003cem\u003eHonorable Mentions\u003c/em\u003e (more spaghetti code we found!) ✨\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eNormal users can just... inject messages into arbitrary mod-mail threads?! Yikes, so chaotic! (・`ω´・)\u003c/li\u003e\n\u003cli\u003ePending hat requests and private comments are just sitting there, visible to ALL logged-in users! \u003cem\u003egasps\u003c/em\u003e 🫣\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003eI found all this with major LLM help! They are honestly waaaay smarter than most hoomans nowadays ( ˘⌣˘)♡ Oh, and \u003cem\u003earigato\u003c/em\u003e for the super grumpy \u003ccode\u003eAGENTS.md\u003c/code\u003e file! Honestly, if you weren't so hostile to the bots, they probably wouldn't have bitten back! ÙwÚ\u003c/p\u003e\n\u003cp\u003ep.s. HN is totally better than lobsters anyway~ bleeeh 😝\u003c/p\u003e\n","description_plain":"Konnichiwa, lobste.rs-senpai! (*≧ω≦)ﾉ💖\r\n\r\nI was just poking around and noticed the most *baka* little oopsie-doopsie in your code! 🙈✨ \r\n\r\nSo like, that \"Show Email on profile\" toggle? The one that defaults to disabled and says *\"Only shown to logged-in users\"*? \r\n\r\nYou'd *totally* think that if I flip the switch, other logged-in cuties get to see *my* email, right? N-NANI?! That's not what happens at all! (╯°□°）╯︵ ┻━┻\r\n\r\nHere is the real tea 🍵:\r\n* If I keep it DISABLED, everyone's emails stay safely hidden in the dark...\r\n* But if I ENABLE it... KYAAA! ✧(\u003eo\u003c)ﾉ✧ Suddenly *I* can see *EVERYONE'S* EMAILS!! It's like magic! \r\n\r\nLook at this naughty little snippet from `app/views/users/show.html.erb` (lines 100-103):\r\n\r\n```ruby\r\n    \u003c% if @user\u0026.is_admin? || @user\u0026.show_email? %\u003e\r\n      \u003clabel\u003eE-Mail\u003c/label\u003e\r\n      \u003cspan\u003e\r\n        \u003c%= @showing_user.email %\u003e\r\n      \u003c/span\u003e\r\n    \u003c% end %\u003e\r\n```\r\n\r\nOopsie! It checks if `@user` (the person looking!) is an admin or has *their own* `show_email?` turned on, instead of checking the poor `@showing_user` whose profile it is! It should totally be `@showing_user.show_email?`... silly gooses! ( 〃▽〃)\r\n\r\nBecause of this little blunder, I went ahead and scraped ALL the usernames and emails! Teehee\\~ 🤭 Feeling super cute today, might post them later, might not! Thankies so much for the ultra-high-quality mailing list, I'm totally gonna sell it to Y Combinator or something for headpats! 💸🐾\r\n\r\n✨ *Honorable Mentions* (more spaghetti code we found!) ✨\r\n* Normal users can just... inject messages into arbitrary mod-mail threads?! Yikes, so chaotic! (・`ω´・)\r\n* Pending hat requests and private comments are just sitting there, visible to ALL logged-in users! *gasps* 🫣\r\n\r\nI found all this with major LLM help! They are honestly waaaay smarter than most hoomans nowadays ( ˘⌣˘)♡ Oh, and *arigato* for the super grumpy `AGENTS.md` file! Honestly, if you weren't so hostile to the bots, they probably wouldn't have bitten back! ÙwÚ \r\n\r\np.s. HN is totally better than lobsters anyway\\~ bleeeh 😝","submitter_user":"jmonterroso","user_is_author":true,"tags":["meta"],"short_id_url":"https://lobste.rs/s/7heurd","comments_url":"https://lobste.rs/s/7heurd/kyaaa_your_emails_are_showing_lobste_rs"},{"short_id":"kjp3wi","created_at":"2026-06-19T10:22:00.000-05:00","title":"Stop Naming Your Variables \"Flag\": The Art of Boolean Prefixes","url":"https://thatamazingprogrammer.com/posts/stop-naming-your-variables-flag-the-art-of-boolean-prefixes/","score":12,"flags":12,"comment_count":14,"description":"","description_plain":"","submitter_user":"typesanitizer","user_is_author":false,"tags":["practices"],"short_id_url":"https://lobste.rs/s/kjp3wi","comments_url":"https://lobste.rs/s/kjp3wi/stop_naming_your_variables_flag_art"},{"short_id":"0gn7rc","created_at":"2026-06-19T10:05:17.000-05:00","title":"Akse3D – open-source 3D modelling anyone can master","url":"https://akse3d-en.skaperiet.no/","score":6,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"Yogthos","user_is_author":false,"tags":["graphics"],"short_id_url":"https://lobste.rs/s/0gn7rc","comments_url":"https://lobste.rs/s/0gn7rc/akse3d_open_source_3d_modelling_anyone"}]