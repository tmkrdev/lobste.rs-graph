[{"short_id":"vcrjmk","created_at":"2026-06-01T11:57:53.000-05:00","title":"Arm desktop: so many cores, not enough speed","url":"https://marcin.juszkiewicz.com.pl/2026/06/01/arm-desktop-so-many-cores-not-enough-speed/","score":2,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"raymii","user_is_author":false,"tags":["hardware"],"short_id_url":"https://lobste.rs/s/vcrjmk","comments_url":"https://lobste.rs/s/vcrjmk/arm_desktop_so_many_cores_not_enough_speed"},{"short_id":"uroflh","created_at":"2026-06-01T11:30:23.000-05:00","title":"Exploring the Japanese XD FirstClass Network BBS","url":"https://cdrom.ca/games/2026/05/30/xd.html","score":2,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"misty","user_is_author":true,"tags":["historical","retrocomputing"],"short_id_url":"https://lobste.rs/s/uroflh","comments_url":"https://lobste.rs/s/uroflh/exploring_japanese_xd_firstclass"},{"short_id":"geifl2","created_at":"2026-06-01T11:14:40.000-05:00","title":"Programmatic Tool Calling for any MCP","url":"https://r33drichards.github.io/mcp-js/concepts/mcp-pass-through/","score":1,"flags":0,"comment_count":0,"description":"\u003cp\u003eYou may have heard of \u003ca href=\"https://platform.claude.com/docs/en/agents-and-tools/tool-use/programmatic-tool-calling\" rel=\"ugc\"\u003eProgrammatic Tool Calling\u003c/a\u003e from anthropic or \u003ca href=\"https://blog.cloudflare.com/code-mode/\" rel=\"ugc\"\u003eCode Mode\u003c/a\u003e from cloudflare for calling mcp servers. I have been working on an open source version of this and recently put together some basic docs, and thought this page would be a good one to share.\u003c/p\u003e\n\u003cp\u003eThere are plenty of other features to explore, but this one alone has resulted in significant improvements in the speed of execution in many tasks including minecraft playing agents, computer use agents, and for querying and aggregating information from my telemetry systems in a lightweight low risk way.\u003c/p\u003e\n","description_plain":"You may have heard of [Programmatic Tool Calling](https://platform.claude.com/docs/en/agents-and-tools/tool-use/programmatic-tool-calling) from anthropic or [Code Mode](https://blog.cloudflare.com/code-mode/) from cloudflare for calling mcp servers. I have been working on an open source version of this and recently put together some basic docs, and thought this page would be a good one to share. \r\n\r\nThere are plenty of other features to explore, but this one alone has resulted in significant improvements in the speed of execution in many tasks including minecraft playing agents, computer use agents, and for querying and aggregating information from my telemetry systems in a lightweight low risk way.","submitter_user":"MrFantastik","user_is_author":false,"tags":["vibecoding"],"short_id_url":"https://lobste.rs/s/geifl2","comments_url":"https://lobste.rs/s/geifl2/programmatic_tool_calling_for_any_mcp"},{"short_id":"vkoa7r","created_at":"2026-06-01T10:36:49.000-05:00","title":"github and the crime against software","url":"https://eblog.fly.dev/githubbad.html","score":9,"flags":0,"comment_count":3,"description":"","description_plain":"","submitter_user":"abnercoimbre","user_is_author":false,"tags":["devops","distributed"],"short_id_url":"https://lobste.rs/s/vkoa7r","comments_url":"https://lobste.rs/s/vkoa7r/github_crime_against_software"},{"short_id":"5yvlsk","created_at":"2026-06-01T10:08:18.000-05:00","title":"Beyond Enumerable: For Want of Better Windows","url":"https://baweaver.com/writing/2026/05/31/beyond-enumerable-for-want-of-better-windows/","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"hibachrach","user_is_author":false,"tags":["ruby"],"short_id_url":"https://lobste.rs/s/5yvlsk","comments_url":"https://lobste.rs/s/5yvlsk/beyond_enumerable_for_want_better"},{"short_id":"lmfm5b","created_at":"2026-06-01T08:37:12.000-05:00","title":"Go Exp