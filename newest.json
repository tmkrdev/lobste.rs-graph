[{"short_id":"5motiw","created_at":"2026-06-14T13:46:19.000-05:00","title":"AI Won’t Fix a Company That Can’t Ship","url":"https://agileproductdevelopment.substack.com/p/ai-wont-fix-a-company-that-cant-ship","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"nrposner","user_is_author":false,"tags":["ai"],"short_id_url":"https://lobste.rs/s/5motiw","comments_url":"https://lobste.rs/s/5motiw/ai_won_t_fix_company_can_t_ship"},{"short_id":"wwbl1n","created_at":"2026-06-14T13:43:40.000-05:00","title":"Even More Batteries Included With Emacs | Karthinks","url":"https://karthinks.com/software/even-more-batteries-included-with-emacs/","score":3,"flags":0,"comment_count":0,"description":"\u003cp\u003eKarthik is an amazing blogger for Emacs.  He's very good at recognizing patterns and conveying how to use them well, and I find his content useful for Emacs beginners and veterans alike.\u003c/p\u003e\n\u003cp\u003eThis post is part of his series on Emacs built-ins (others are linked in the post).  Check it out!  I've been an Emacs user for ~10 years, and each of these 'batteries included' articles revealed something new to me.  Emacs's depth makes sense when you consider Elisp, and how easy it is for 3rd parties to define their own extensions.  It's amazing how much is actually built into Emacs.  I've found myself replacing a lot of my 3rd party packages with the Emacs built-ins, and it's been a lovely experience.\u003c/p\u003e\n","description_plain":"Karthik is an amazing blogger for Emacs.  He's very good at recognizing patterns and conveying how to use them well, and I find his content useful for Emacs beginners and veterans alike.  \r\n\r\nThis post is part of his series on Emacs built-ins (others are linked in the post).  Check it out!  I've been an Emacs user for ~10 years, and each of these 'batteries included' articles revealed something new to me.  Emacs's depth makes sense when you consider Elisp, and how easy it is for 3rd parties to define their own extensions.  It's amazing how much is actually built into Emacs.  I've found myself replacing a lot of my 3rd party packages with the Emacs built-ins, and it's been a lovely experience.","submitter_user":"chiply","user_is_author":false,"tags":["emacs"],"short_id_url":"https://lobste.rs/s/wwbl1n","comments_url":"https://lobste.rs/s/wwbl1n/even_more_batteries_included_with_emacs"},{"short_id":"7bujlv","created_at":"2026-06-14T12:43:02.000-05:00","title":"ERD Generator from SQL","url":"https://sqltoerdiagram.com/","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"cohix","user_is_author":false,"tags":["databases"],"short_id_url":"https://lobste.rs/s/7bujlv","comments_url":"https://lobste.rs/s/7bujlv/erd_generator_from_sql"},{"short_id":"3cv4k9","created_at":"2026-06-14T12:35:54.000-05:00","title":"No, everyone is not using AI for everything","url":"https://gabrielweinberg.com/p/people-are-consuming-ai-like-they","score":-1,"flags":2,"comment_count":0,"description":"","description_plain":"","submitter_user":"cohix","user_is_author":false,"tags":["ai","vibecoding"],"short_id_url":"https://lobste.rs/s/3cv4k9","comments_url":"https://lobste.rs/s/3cv4k9/no_everyone_is_not_using_ai_for_everything"},{"short_id":"daehjf","created_at":"2026-06-14T12:12:27.000-05:00","title":"FFI in Miri at 8000 segfaults per second","url":"https://youtu.be/9X-ngiKo_Y0","score":6,"flags":0,"comment_count":0,"description":"\u003cp\u003eTalk by Nia Deckers at RustWeek\u003c/p\u003e\n","description_plain":"Talk by Nia Deckers at RustWeek","submitter_user":"jana","user_is_author":false,"tags":["compilers","rust","video"],"short_id_url":"https://lobste.rs/s/daehjf","comments_url":"https://lobste.rs/s/daehjf/ffi_miri_at_8000_segfaults_per_second"},{"short_id":"lvodx4","created_at":"2026-06-14T12:07:42.000-05:00","title":"Deconstructing Datalog","url":"https://www.rntz.net/post/my-thesis.html","score":17,"flags":0,"comment_count"