[{"short_id":"kn47yj","created_at":"2026-06-20T07:54:11.000-05:00","title":"The AI Slop Comes Before the Skill","url":"https://www.mfrantzen.com/p/the-ai-slop-comes-before-the-skill","score":-1,"flags":2,"comment_count":1,"description":"\u003cp\u003eI think the workforce is splitting into two camps: people building fluency with AI, and people rejecting it on principle.\u003c/p\u003e\n\u003cp\u003eThe pattern feels familiar.\u003c/p\u003e\n\u003cp\u003eDuring the Industrial Revolution, the Luddites resisted mechanized automation for reasons that were not entirely irrational: worker pay, loss of craft, deskilling, and lower-quality mass production. Some of those concerns rhyme with what we hear today about AI.\u003c/p\u003e\n\u003cp\u003eBut when I see “AI slop,” I often see something different.\u003c/p\u003e\n","description_plain":"I think the workforce is splitting into two camps: people building fluency with AI, and people rejecting it on principle.\r\n\r\nThe pattern feels familiar.\r\n\r\nDuring the Industrial Revolution, the Luddites resisted mechanized automation for reasons that were not entirely irrational: worker pay, loss of craft, deskilling, and lower-quality mass production. Some of those concerns rhyme with what we hear today about AI.\r\n\r\nBut when I see “AI slop,” I often see something different.","submitter_user":"jsc","user_is_author":false,"tags":["ai"],"short_id_url":"https://lobste.rs/s/kn47yj","comments_url":"https://lobste.rs/s/kn47yj/ai_slop_comes_before_skill"},{"short_id":"lhn5w5","created_at":"2026-06-20T06:49:16.000-05:00","title":"Reverse Engineering the Qualcomm NPU Compiler","url":"https://datavorous.github.io/writing/qairt/","score":1,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"mrunix","user_is_author":false,"tags":["reversing"],"short_id_url":"https://lobste.rs/s/lhn5w5","comments_url":"https://lobste.rs/s/lhn5w5/reverse_engineering_qualcomm_npu"},{"short_id":"rdrtip","created_at":"2026-06-2